{
  "schema_version": 1,
  "repo_id": "homelab-analytics",
  "adoption_level": "dispatchable",
  "routing": {
    "default_harness": "claude",
    "default_model_alias": "fast-build",
    "action_classes": {
      "plan": { "enabled": true, "model_alias": "frontier-plan" },
      "build": { "enabled": true, "model_alias": "fast-build", "review_required": true },
      "review": { "enabled": true, "model_alias": "review-synthesis" },
      "verify": { "enabled": true, "model_alias": "review-synthesis", "review_required": true },
      "reconcile": { "enabled": true, "model_alias": "review-synthesis" }
    }
  },
  "skills": {
    "template_root": "/projects/dev/agentops/templates/dispatch/skills",
    "selected": [
      "dispatch-plan",
      "dispatch-build",
      "dispatch-review",
      "code-change-verification",
      "backlog-refinement",
      "sprint-maintenance",
      "task-pickup",
      "plan-review",
      "model-routing-optimizer",
      "pr-handoff-summary",
      "sprint-resume",
      "sprint-packet",
      "item-done",
      "sprint-snapshot",
      "kctl-extract",
      "sprint-close",
      "domain-impact-scan",
      "workflow-artifact-capture",
      "verify-state-protocols",
      "reconcile-project-contracts"
    ],
    "overlays": [".agents/overlays/homelab-analytics.dispatch-workflows.md"]
  },
  "scope": {
    "allowed_path_roots": ["apps/", "packages/", "migrations/", "tests/", "docs/", "verification/", ".agents/"],
    "out_of_scope": ["deployment manifests unless explicitly in scope"]
  },
  "verification": {
    "command_families": ["unit", "lint", "typecheck", "architecture", "full-suite"],
    "targeted_first": true,
    "commands": [
      "ruff check <changed-python-files>",
      "mypy <changed-python-files>",
      "pytest <specific-test-files> -x --tb=short",
      "python /projects/dev/agentops/templates/dispatch/scripts/validate_verification_artifacts.py --root .",
      "make verify-fast"
    ]
  },
  "hooks": {
    "level": "verification",
    "publishers": ["git", "actionq-daemon", "workspace-cost", "dispatcher-gate"]
  }
}