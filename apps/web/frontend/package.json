{
  "name": "homelab-analytics-web",
  "private": true,
  "scripts": {
    "tokens:build": "node scripts/build-ui-tokens.mjs",
    "tokens:check": "node scripts/build-ui-tokens.mjs --check",
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen.mjs --check",
    "contracts:check": "node scripts/check-transport-contracts.mjs",
    "build": "npm run tokens:build && next build",
    "dev": "npm run tokens:build && next dev",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "storybook": "npm run tokens:build && storybook dev -p 6006 --ci",
    "storybook:build": "npm run tokens:build && storybook build",
    "playwright:test": "playwright test",
    "playwright:test:update": "playwright test --update-snapshots",
    "ui:test": "start-server-and-test storybook http://127.0.0.1:6006 playwright:test"
  },
  "dependencies": {
    "next": "^14.2.0",
    "openapi-fetch": "^0.13.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^8.6.15",
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-interactions": "^8.6.15",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.15",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "msw": "^2.11.6",
    "msw-storybook-addon": "^2.0.6",
    "openapi-typescript": "^7.6.1",
    "start-server-and-test": "^2.0.10",
    "storybook": "^8.6.15",
    "typescript": "^5.8.2",
    "vite": "^5.4.21"
  }
}
