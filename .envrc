# Project environment is defined once in tools/project-env.sh so direnv, the
# Makefile, and agent shells all load identical values. This file adds only
# the human/direnv fail-fast assertion -- served mode (the default since
# 2026-07-24) needs no SPRINTCTL_URL, so the assertion only fires for the
# direct-remote rollback path (SPRINTCTL_BACKEND=remote set via
# .env.sprintctl.local).
_envrc_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
. "${_envrc_dir}/tools/project-env.sh"
unset _envrc_dir

if [ "${SPRINTCTL_BACKEND:-}" = "remote" ]; then
  export SPRINTCTL_URL="${SPRINTCTL_URL:?Set SPRINTCTL_URL from an injected secret or local shell before entering this repo}"
fi
