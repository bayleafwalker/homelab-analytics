repo_root="${DIRENV_DIR#-}"
if [ -z "${repo_root}" ] || [ "${repo_root}" = "${DIRENV_DIR}" ]; then
  repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

# duckdb needs libstdc++ which is not on the default path when the venv is built
# against the workstation Python rather than the devbox image Python. The exact
# gcc store hash rotates on each nix update, so glob for a current one instead
# of pinning a specific hash that will silently go stale.
for _gcc_lib in /nix/store/*-gcc-*-lib/lib; do
  if [ -f "${_gcc_lib}/libstdc++.so.6" ]; then
    export LD_LIBRARY_PATH="${_gcc_lib}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
    break
  fi
done
unset _gcc_lib

export SPRINTCTL_DB="${repo_root}/.sprintctl/sprintctl.db"
export SPRINTCTL_BACKEND=remote
if [ -d "/home/dev/.local/bin" ]; then
  case ":${PATH}:" in
    *":/home/dev/.local/bin:"*) ;;
    *) export PATH="/home/dev/.local/bin:${PATH}" ;;
  esac
fi
if [ -f "${repo_root}/.env.sprintctl.local" ]; then
  source "${repo_root}/.env.sprintctl.local"
fi
export SPRINTCTL_URL="${SPRINTCTL_URL:?Set SPRINTCTL_URL from an injected secret or local shell before entering this repo}"
export KCTL_DB="${repo_root}/.kctl/kctl.db"
export AUDITCTL_DB="${repo_root}/.auditctl/auditctl.db"
export AUDITCTL_ARTIFACTS_ROOT="/projects/dev"
