# Project environment is defined once in tools/project-env.sh so direnv, the
# Makefile, and agent shells all load identical values. This file adds only the
# human/direnv fail-fast assertion on the injected secret.
_envrc_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
. "${_envrc_dir}/tools/project-env.sh"
unset _envrc_dir

export SPRINTCTL_URL="${SPRINTCTL_URL:?Set SPRINTCTL_URL from an injected secret or local shell before entering this repo}"
